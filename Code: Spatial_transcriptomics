    theme_minimal() +
    theme(
      plot.title = element_text(hjust = 0.5),
      legend.position = "right"
    )
  
  ggsave(
    filename = file.path(output_dir, paste0(safe_name, "_TR.png")),
    plot = p,
    width = 5,
    height = 4
  )
}


# With seperate colours for ROI
