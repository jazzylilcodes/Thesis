## Upset plot
```{r UpSet plot, include = FALSE}
# prepare the data for UpSet plots. Rows represent proteins, columns represent runs. 1 and 0 are used to represent whether the protein was detected in that sample or not.
# Create a list of all proteins to search against
All_proteins <- as.character(unique(Proteins$Accession))
All_runs <- as.character(unique(Proteins$Run))

# Pivot wider to create the matrix
UpSet_matrix <- Proteins %>%
  mutate(present = 1) %>%
  pivot_wider(
    id_cols = Accession,
    names_from = Run,
    values_from = present,
    values_fill = 0
  )

# Make the plot per Sample
for (i in unique(Run_annotations$Sample)) {
  # Make a list of runs to include
  selected_runs <- Run_annotations %>%
    filter(Sample == i) %>%
    pull(Run) %>%
    as.character()

  # make the plot
  upset(
    UpSet_matrix,
    selected_runs,
    name = "Run intersections",
    width_ratio = 0.1,
    height_ratio = 0.3,
    n_intersections = 15,
    base_annotations = list(
      "Protein identifications" = intersection_size(text_mapping = aes(label = !!upset_text_percentage()))
    ),
    min_degree = 1
  )

  # Save the plot
  ggsave(paste0(output_dir, "/Upset_plots/Sample ", i, " UpSet plot.png"), width = 8 * 2, height = 5.5 * 2)
}
```

