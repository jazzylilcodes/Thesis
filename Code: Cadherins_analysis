library(dplyr)
library(tidyr)
library(readr)
library(ggplot2)

output_dir <- "N and P cad cell profiler analysis"
  dir.create(output_dir, showWarnings = FALSE)

Nuclei <- CellProfiler_nuclei_analysis
Cells <- CellProfiler_cell_analysis

Merged <- Cells %>%
  inner_join(
    Nuclei,
    by = c("ImageNumber" = "ImageNumber", 
           "Parent_Nuclei" = "Number_Object_Number")
  )

# ---- Group by Image and summarise ----
summary_data <- Merged %>%
  group_by(ImageNumber) %>%   # Replace with correct column name if different
  summarise(
    mean_intensity_DAPI  = mean(Intensity_MeanIntensity_DAPI, na.rm = TRUE),
    mean_intensity_Ncad  = mean(Intensity_MeanIntensity_Ncad, na.rm = TRUE),
    mean_intensity_Pcad  = mean(Intensity_MeanIntensity_Pcad, na.rm = TRUE),
    
    median_intensity_DAPI  = mean(Intensity_MedianIntensity_DAPI, na.rm = TRUE),
    median_intensity_Ncad  = mean(Intensity_MedianIntensity_Ncad, na.rm = TRUE),
    median_intensity_Pcad  = mean(Intensity_MedianIntensity_Pcad, na.rm = TRUE),
    
    max_intensity_DAPI   = mean(Intensity_MaxIntensity_DAPI, na.rm = TRUE),
    max_intensity_Ncad   = mean(Intensity_MaxIntensity_Ncad, na.rm = TRUE),
    max_intensity_Pcad   = mean(Intensity_MaxIntensity_Pcad, na.rm = TRUE),
    
    std_intensity_DAPI   = mean(Intensity_StdIntensity_DAPI, na.rm = TRUE),
    std_intensity_Ncad   = mean(Intensity_StdIntensity_Ncad, na.rm = TRUE),
    std_intensity_Pcad   = mean(Intensity_StdIntensity_Pcad, na.rm = TRUE),
    
    uq_intensity_DAPI    = mean(Intensity_UpperQuartileIntensity_DAPI, na.rm = TRUE),
    uq_intensity_Ncad    = mean(Intensity_UpperQuartileIntensity_Ncad, na.rm = TRUE),
    uq_intensity_Pcad    = mean(Intensity_UpperQuartileIntensity_Pcad, na.rm = TRUE),
    
    mean_intensity_edge_DAPI  = mean(Intensity_MeanIntensityEdge_DAPI, na.rm = TRUE),
    mean_intensity_edge_Ncad  = mean(Intensity_MeanIntensityEdge_Ncad, na.rm = TRUE),
    
    max_intensity_edge_DAPI   = mean(Intensity_MaxIntensityEdge_DAPI, na.rm = TRUE),
    max_intensity_edge_Ncad   = mean(Intensity_MaxIntensityEdge_Ncad, na.rm = TRUE),
    
    std_intensity_edge_DAPI   = mean(Intensity_StdIntensityEdge_DAPI, na.rm = TRUE),
    std_intensity_edge_Ncad   = mean(Intensity_StdIntensityEdge_Ncad, na.rm = TRUE),
  )


# ---- Normalise Ncad by DAPI ----
summary_data <- summary_data %>%
  mutate(
    norm_mean_Ncad_intensity   = mean_intensity_Ncad / mean_intensity_DAPI,
    norm_median_Ncad_intensity   = median_intensity_Ncad / median_intensity_DAPI,
    norm_max_Ncad_intensity    = max_intensity_Ncad / max_intensity_DAPI,
    norm_std_Ncad_intensity    = std_intensity_Ncad / std_intensity_DAPI,
    norm_uq_Ncad_intensity     = uq_intensity_Ncad / uq_intensity_DAPI,
    norm_mean_Ncad_intensityEdge   = mean_intensity_edge_Ncad / mean_intensity_edge_DAPI,
    norm_max_Ncad_intensityEdge    = max_intensity_edge_Ncad / max_intensity_edge_DAPI,
    norm_std_Ncad_intensityEdge    = std_intensity_edge_Ncad / std_intensity_edge_DAPI,
    norm_mean_Pcad_intensity   = mean_intensity_Pcad / mean_intensity_DAPI,
    norm_median_Pcad_intensity   = median_intensity_Pcad / median_intensity_DAPI,
    norm_max_Pcad_intensity    = max_intensity_Pcad / max_intensity_DAPI,
    norm_std_Pcad_intensity    = std_intensity_Pcad / std_intensity_DAPI,
    norm_uq_Pcad_intensity     = uq_intensity_Pcad / uq_intensity_DAPI,
  )

summary_data <- summary_data %>%
  mutate(CellLine = case_when(
    ImageNumber == 1 ~ "20-201",
    ImageNumber == 2 ~ "21-199",
    ImageNumber == 3 ~ "22-029",
