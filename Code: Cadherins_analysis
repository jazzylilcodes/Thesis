# Define your groups based on ranked groups from size/density analysis
# Define groups (ranked off size/density)
summary_data <- summary_data %>%
  mutate(Group = case_when(
    CellLine %in% c("21-199", "22-029", "22-042", "22-043") ~ "A",
    CellLine %in% c("20-201", "22-089", "22-097", "22-110") ~ "B",
    TRUE ~ NA_character_
  ))

# Identify numeric columns (exclude CellLine, Group, etc.)
numeric_cols <- summary_data %>%
  select(where(is.numeric)) %>%
  colnames()
library(dplyr)
library(purrr)
library(broom)  # for tidy p-value output

# Run t-test for each column
stats_results <- map_dfr(numeric_cols, function(col) {
  t_result <- t.test(summary_data[[col]] ~ summary_data$Group)
  tibble(
    Variable = col,
    GroupA_Mean = mean(summary_data[[col]][summary_data$Group == "A"], na.rm = TRUE),
    GroupB_Mean = mean(summary_data[[col]][summary_data$Group == "B"], na.rm = TRUE),
    p_value = t_result$p.value
  )
}) %>%
  mutate(Significance = case_when(
    p_value < 0.001 ~ "***",
    p_value < 0.01  ~ "**",
    p_value < 0.05  ~ "*",
    TRUE ~ "ns"
  ))

stats_results

