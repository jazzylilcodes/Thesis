##	Statistical comparison between groups for neurosphere area 
# Define groups (ranked off size/density) 
group_aI <- c("21-199", "22-029", "22-042", "22-043", "22-065") 
group_bI <- c("20-201", "22-073", "22-097", "22-089", "22-110") 
 
# Add a new column for grouping 
df_2500 <- df_2500 %>% 
  mutate(GroupI = case_when( 
    CellLine %in% group_aI ~ "AI", 
    CellLine %in% group_bI ~ "BI", 
    TRUE ~ NA_character_ 
  )) 
 
# Group mean area of each image to defined groups 
cellarea_means <- df_2500 %>% 
  group_by(CellLine, GroupI) %>% 
  summarise(MeanArea = mean(Area, na.rm = TRUE)) %>% 
  ungroup() 
 
# run test and print p value 
wilcox_result <- wilcox.test( 
  MeanArea ~ GroupI, 
  data = cellarea_means, 
  exact = FALSE 
) 
 
wilcox_result 
 
# stats not of the mean, but all values 
t.test(cellarea_means ~ Group, data = cellarea_means) 
 
wilcox.test(cellarea_means ~ Group, data = cellarea_means) 
 
# Run Wilcoxon rank-sum test (Mann–Whitney U) 
wilcox_result <- wilcox.test( 
  NormalizedIntensity ~ Group, 
  data = cellarea_means, 
  exact = FALSE  # avoids warning if sample sizes differ 
) 
 
# Print the p-value 
wilcox_result$p.value 
 
